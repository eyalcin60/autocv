{
  "include": ["electron/**/*"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist-electron",
    "target": "es2020",
    "lib": ["es2020"],
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "strictNullChecks": true
  }
}
